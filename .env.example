# Digital Catalogue App Environment Variables

# Database (Optional - for storing submissions)
# DATABASE_URL=postgresql://username:password@localhost:5432/catalogue_db

# Email Service (Optional - for notifications)
# EMAIL_API_KEY=your-email-service-api-key
# EMAIL_FROM=noreply@yourdomain.com
# ADMIN_EMAIL=admin@yourdomain.com

# SMTP Configuration (Alternative to email service)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Application Settings
# NEXT_PUBLIC_APP_NAME="Digital Catalogue"
# NEXT_PUBLIC_MAX_FILE_SIZE=10485760
# NEXT_PUBLIC_CONTACT_EMAIL=contact@yourdomain.com

# Development
# NODE_ENV=development